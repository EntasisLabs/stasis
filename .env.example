# Stasis local environment template.
# Copy to `.env` and adjust values for local development.
# Existing process environment variables always take precedence over `.env`.

# Optional alternate dotenv path (default: `.env` in the working directory)
# STASIS_ENV_FILE=.env.local

# Optional directory of one-file-per-secret (Vault Agent / External Secrets file sinks)
# STASIS_SECRETS_DIR=/vault/secrets

# LLM routing (used by GenaiChatClient / GenaiLlmGateway)
STASIS_LLM_PROVIDER=openai
STASIS_LLM_MODEL=gpt-4o-mini
# STASIS_LLM_API_KEY=
# STASIS_OPENAI_API_KEY=

# Surreal dashboard runtime (see docs-book/src/runtime-builder.md)
# STASIS_DASHBOARD_RUNTIME_BACKEND=in-memory
# STASIS_DASHBOARD_ADDR=127.0.0.1:3007
# STASIS_DASHBOARD_SURREAL_NAMESPACE=stasis
# STASIS_DASHBOARD_SURREAL_DATABASE=runtime
# STASIS_DASHBOARD_SURREAL_ENDPOINT=ws://127.0.0.1:8000/rpc
# STASIS_DASHBOARD_SURREAL_USERNAME=root
# STASIS_DASHBOARD_SURREAL_PASSWORD=root

# Dashboard auth (optional)
# STASIS_DASHBOARD_ACTION_AUTH_BEARER=
# STASIS_DASHBOARD_ACTION_REQUIRED_ROLE=
# STASIS_DASHBOARD_DEMO_SEED=false
# STASIS_DASHBOARD_LOCUS_MEMORY=false
# STASIS_DASHBOARD_LOGGING_CHAT=false

# Identity defaults (optional)
# STASIS_DEFAULT_PERSONA_ID=persona:default
# STASIS_DEFAULT_CHANNEL_ID=channel:default

# OpenTelemetry (requires `cargo build --features otel`)
# Run dashboard with OTEL: cargo run --features otel --bin stasis_dashboard
# STASIS_OTEL_ENABLED=true
# STASIS_OTEL_SERVICE_NAME=stasis-runtime
# STASIS_OTEL_TRACE_PROPAGATION=w3c
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# OTEL_SERVICE_NAME=stasis-runtime
# Dashboard HTTP actions accept W3C `traceparent` and propagate trace ids to jobs enqueued during the request.
